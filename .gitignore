# ── Python ──────────────────────────────────────────────────────────────────
__pycache__/
*.pyc
*.pyo
.venv/

# ── HFSS simulation result directories ──────────────────────────────────────
# These are generated by HFSS and can be re-created by re-running simulations
*.aedtresults/
*.aedtresults

# ── Lock files (HFSS open-project markers) ───────────────────────────────────
*.aedt.lock

# ── Intermediate sweep/derived simulation folders ────────────────────────────
# Contain hundreds of parameterised .aedt + .s3p files (~100 GB)
**/derived/
**/runs/

# ── Raw simulation data file types ───────────────────────────────────────────
*.su
*.stats
*.profile
*.conv
*.EMConvData
*.ngmesh
*.tvm
*.tvc
*.tvz
*.nvc
*.adp
*.asol
*.asol_priv
*.semaphore
*.bmp
*.settings

# ── S-parameter results (keep only final/) ───────────────────────────────────
*.s3p
!12GHzdiplexer2/final/*.s3p

# ── Temporary inspection / scratch scripts ────────────────────────────────────
_inspect_185.py
_parse_185_result.py

# ── Generated JSON inspection dumps (keep only hand-curated ones) ────────────
inspect.json
update_result.json
